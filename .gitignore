###############################################################################
# DISTRIBUTED AI DEMO — PRODUCTION .gitignore
#
# Covers:
# - Django backend
# - Celery workers
# - Kafka consumers/producers
# - Docker / docker compose
# - Poetry environments
# - CI/CD safe defaults
# - Windows + WSL compatibility
###############################################################################


###############################################################################
# Python bytecode / cache
###############################################################################
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.so
*.dylib


###############################################################################
# Python packaging / build artifacts
###############################################################################
build/
dist/
*.egg-info/
.eggs/
*.egg


###############################################################################
# Poetry environments
###############################################################################
.venv/
venv/
*.venv
__pypackages__/


###############################################################################
# Environment variables (secrets)
###############################################################################
.env
.env.*
!.env.example


###############################################################################
# Django
###############################################################################
db.sqlite3
*.sqlite3
media/
staticfiles/
static/

# Django collected static
static_root/

# Django migrations cache (optional — keep migrations themselves!)
**/migrations/*.pyc


###############################################################################
# Logs
###############################################################################
*.log
logs/
*.out
*.err


###############################################################################
# Celery
###############################################################################
celerybeat-schedule
celerybeat.pid
celerybeat-schedule.*
celery-worker.log


###############################################################################
# Redis
###############################################################################
dump.rdb
appendonly.aof


###############################################################################
# Kafka / Zookeeper local data
###############################################################################
kafka-logs/
zookeeper/
*.kafka


###############################################################################
# Docker
###############################################################################
docker-compose.override.yml
docker-data/
*.pid

# docker volumes (local)
volumes/
data/


###############################################################################
# Docker Desktop / WSL temporary
###############################################################################
*.swp
*.swo
*.tmp


###############################################################################
# IDE / Editor
###############################################################################
.vscode/
.idea/
.history/
*.code-workspace


###############################################################################
# Node / frontend (UI)
###############################################################################
node_modules/
package-lock.json
yarn.lock
npm-debug.log


###############################################################################
# Testing
###############################################################################
.pytest_cache/
.coverage
htmlcov/
coverage.xml


###############################################################################
# Type checking
###############################################################################
.mypy_cache/
.pyre/


###############################################################################
# Ruff / lint cache
###############################################################################
.ruff_cache/


###############################################################################
# Jupyter notebooks (AI experimentation)
###############################################################################
.ipynb_checkpoints/


###############################################################################
# OS files
###############################################################################
.DS_Store
Thumbs.db


###############################################################################
# AI / ML artifacts
###############################################################################
models/
checkpoints/
*.pt
*.pth
*.onnx
*.ckpt


###############################################################################
# Temporary files
###############################################################################
tmp/
temp/
*.temp
*.bak


###############################################################################
# Local runtime state
###############################################################################
runtime/
pids/
*.pid.lock


###############################################################################
# Mongo (if local volume created)
###############################################################################
mongo-data/


###############################################################################
# Postgres (if local volume created)
###############################################################################
postgres-data/


###############################################################################
# Distributed system debugging
###############################################################################
events.log
consumer.log
producer.log
worker.log


###############################################################################
# Optional: keep example configs tracked
###############################################################################
!.env.example
!docker-compose.yml
